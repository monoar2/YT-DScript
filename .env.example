# Jellyfin Docker Compose Environment Variables - EXAMPLE
# Copy to .env and fill in your actual values

# User and Group IDs (run `id -u` and `id -g` to get these)
USER_ID=1000
GROUP_ID=1000

# Port Configuration
JELLYFIN_PORT=8096
JELLYFIN_CLIENT_PORT=7359

# Path Configuration - USE ABSOLUTE PATHS
JELLYFIN_CONFIG_PATH=/path/to/your/jellyfin/config
JELLYFIN_CACHE_PATH=/path/to/your/jellyfin/cache
MEDIA_PATH=/path/to/your/media/library

# Optional: Transcode directory
# TRANSCODE_PATH=/tmp/jellyfin

# Optional: Timezone
# TIMEZONE=America/New_York

# Optional: Hardware Acceleration
# HWACCEL=vaapi
# VAAPI_DEVICE=/dev/dri/renderD128